<section class="contrib-shell" data-username="lemonsix">
  <div class="contrib-content">
    <div class="contrib-loading" aria-live="polite" aria-busy="true">
      <p class="contrib-loading-text">Loading contribution graph…</p>
      <div class="contrib-spinner" aria-hidden="true"></div>
    </div>
  </div>
</section>

<script>
  import { loadContributions } from "@/lib/contributions-client";

  for (const root of document.querySelectorAll<HTMLElement>(".contrib-shell")) {
    if (root.dataset.loaded === "true") continue;
    root.dataset.loaded = "true";
    loadContributions(root);
  }
</script>
