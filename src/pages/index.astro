---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.astro";
import ExperienceList from "@/components/ExperienceList.astro";
import SkillsBlock from "@/components/SkillsBlock.astro";
import ProjectsList from "@/components/ProjectsList.astro";
import ContributionGraph from "@/components/ContributionGraph.astro";

import type {
  Profile,
  Experience,
  Skill,
  Project,
} from "@/types/portfolio";

import profileData from "@/data/profile.json";
import experienceData from "@/data/experience.json";
import skillsData from "@/data/skills.json";
import projectsData from "@/data/projects.json";

import { metaDescription, personJsonLd } from "@/lib/seo";

const profile = profileData as Profile;
const experience = experienceData as Experience[];
const skills = skillsData as Skill[];
const projects = projectsData as Project[];

const jsonLd = personJsonLd(profile, skills);
---

<Base
  meta={{
    title: "Portfolio",
    description: metaDescription(profile),
  }}
  jsonLd={jsonLd}
>
  <Hero profile={profile} />

  <section class="writing">
    <h2 class="section-label">Experience</h2>
    <ExperienceList items={experience} />
  </section>

  <SkillsBlock items={skills} />

  <section class="work">
    <h2 class="section-label">Personal projects</h2>
    <ProjectsList items={projects} />
  </section>

  <section class="activity">
    <h2 class="section-label">Activity</h2>
    <ContributionGraph />
  </section>
</Base>

<style>
  .writing {
    margin-bottom: 96px;
  }
  .work {
    margin-bottom: 88px;
  }
  .activity {
    margin-bottom: 64px;
  }

  @media (max-width: 720px) {
    .writing {
      margin-bottom: 64px;
    }
    .work {
      margin-bottom: 56px;
    }
  }
</style>
